# =====================================================================
# CHIA-BILL SPRING BOOT BACKEND ENVIRONMENT VARIABLES (TEMPLATE)
# =====================================================================

# Cấu hình kết nối CSDL (Dùng host.docker.internal để kết nối PostgreSQL chạy trực tiếp trên host VPS)
SPRING_DATASOURCE_URL=jdbc:postgresql://host.docker.internal:5432/chiabill
SPRING_DATASOURCE_USERNAME=chiabill_user
SPRING_DATASOURCE_PASSWORD=change_me_to_secure_password

# JWT Secret Key (Tối thiểu 32 ký tự để đảm bảo thuật toán HS256 bảo mật)
JWT_SECRET=change_me_to_a_very_long_random_string_at_least_32_characters

# Google OAuth2 Client ID
GOOGLE_CLIENT_ID=change_me_google_client_id.apps.googleusercontent.com

# Spring Profile hoạt động (mặc định là prod khi deploy)
SPRING_PROFILES_ACTIVE=prod

# Cloudinary (Quản lý ảnh album và địa điểm)
CLOUD_NAME=change_me
API_KEY=change_me
API_SECRET=change_me

# Mail Sender (Gửi mail mời tham gia chuyến đi)
MAIL_USERNAME=your_gmail_username@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# Địa chỉ URL gốc của Server Backend (Dùng cho DeepLink) và Link tải ứng dụng
BASE_URL=https://chiabill-server.onrender.com
DOWNLOAD_LINK=https://chiabill.com/download

# Cổng lắng nghe của máy chủ
SERVER_PORT=8080

# Đường dẫn tệp key Firebase Admin SDK phục vụ push notification
FIREBASE_KEY_PATH=chiabill-firebase.json

# Tùy chọn tối ưu hóa bộ nhớ JVM cho VPS khi chạy Docker
JAVA_OPTS=-Xms256m -Xmx768m -XX:+UseG1GC

